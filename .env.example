# ── Deployment: Azure Static Web Apps ──────────────────────────────────────
# In production, the app uses Managed Identity — NO secrets needed here.
# Enable system-assigned Managed Identity on your Static Web App in Azure Portal,
# then grant it these Microsoft Graph API permissions (Application):
#   Files.ReadWrite.All   — OneDrive folder and file operations
#   Sites.ReadWrite.All   — Excel workbook operations
#   Mail.Send             — Sending emails on behalf of EMAIL_FROM
#
# For LOCAL DEV only: copy api/local.settings.json.example → api/local.settings.json
# and fill in AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET there.
# local.settings.json is gitignored and never deployed.

# ── OneDrive ────────────────────────────────────────────────────────────────
# Top-level folder where client folders are created.
# e.g. "Mownur Clients" → creates "Mownur Clients/Jane Doe - 1234/"
ONEDRIVE_FOLDER=Mownur Clients

# M365 user whose OneDrive and mailbox the app acts on.
# Azure app needs Files.ReadWrite.All and Mail.Send for this account.
ONEDRIVE_USER_ID=admin@mownurservices.com

# ── Excel Database ──────────────────────────────────────────────────────────
# Item ID of the Excel file in OneDrive used as the client database.
# Find it in the OneDrive file URL after "items/"
# File must contain a table named "ClientDatabase" with these columns (in order):
# firstName | lastName | email | phone | filingStatus | incomeTypes | lifeChanges
# dependentsCount | submittedAt | status | statusUpdatedAt | underReviewAt
# filedAt | completedAt | oneDriveFolderUrl | notes | last4
EXCEL_FILE_ID=your-excel-file-item-id

# ── Teams Webhook ───────────────────────────────────────────────────────────
# Incoming webhook URL from Teams channel connector.
# Teams → channel → ··· → Connectors → Incoming Webhook → Copy URL
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# ── Admin Panel ─────────────────────────────────────────────────────────────
# Password to authenticate /api/admin-update calls. Use a strong, unique value.
ADMIN_PASSWORD=choose-a-strong-password-here

# ── Email ───────────────────────────────────────────────────────────────────
# "From" address for all outgoing emails (confirmation + status updates).
# Must be a mailbox the Azure app has Mail.Send permission for.
EMAIL_FROM=admin@mownurservices.com

# ── Site URL (optional) ─────────────────────────────────────────────────────
# Production domain — used to build links in Teams messages and emails.
SITE_URL=https://mownurservices.com
